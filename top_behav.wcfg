<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="top_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="top" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="1,000,000 ps"></ZoomStartTime>
      <ZoomEndTime time="1,000,002 ps"></ZoomEndTime>
      <Cursor1Time time="1,000,000 ps"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="404"></NameColumnWidth>
      <ValueColumnWidth column_width="190"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="10" />
   <wvobject fp_name="/top/A" type="array">
      <obj_property name="ElementShortName">A[3:0]</obj_property>
      <obj_property name="ObjectShortName">A[3:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/top/B" type="array">
      <obj_property name="ElementShortName">B[3:0]</obj_property>
      <obj_property name="ObjectShortName">B[3:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/top/sel" type="array">
      <obj_property name="ElementShortName">sel[2:0]</obj_property>
      <obj_property name="ObjectShortName">sel[2:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/top/mode" type="logic">
      <obj_property name="ElementShortName">mode</obj_property>
      <obj_property name="ObjectShortName">mode</obj_property>
   </wvobject>
   <wvobject fp_name="/top/result" type="array">
      <obj_property name="ElementShortName">result[7:0]</obj_property>
      <obj_property name="ObjectShortName">result[7:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/top/overflow" type="logic">
      <obj_property name="ElementShortName">overflow</obj_property>
      <obj_property name="ObjectShortName">overflow</obj_property>
   </wvobject>
   <wvobject fp_name="/top/int_result" type="array">
      <obj_property name="ElementShortName">int_result[7:0]</obj_property>
      <obj_property name="ObjectShortName">int_result[7:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/top/float_result" type="array">
      <obj_property name="ElementShortName">float_result[7:0]</obj_property>
      <obj_property name="ObjectShortName">float_result[7:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/top/ov_int" type="logic">
      <obj_property name="ElementShortName">ov_int</obj_property>
      <obj_property name="ObjectShortName">ov_int</obj_property>
   </wvobject>
   <wvobject fp_name="/top/ov_float" type="logic">
      <obj_property name="ElementShortName">ov_float</obj_property>
      <obj_property name="ObjectShortName">ov_float</obj_property>
   </wvobject>
</wave_config>
